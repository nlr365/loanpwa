# ==========================================
# LOAN PWA - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your credentials
# ==========================================

# Server Configuration
PORT=3000
NODE_ENV=development

# ==========================================
# WHATSAPP BUSINESS API (Meta Cloud API)
# Get these from: https://developers.facebook.com/
# ==========================================

# Your Meta Developer Access Token
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here

# Your WhatsApp Business Account Phone Number ID
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here

# Webhook Verification Token (create your own random string)
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_123456

# Your Business Phone Number (with country code, e.g., +919500526217)
BUSINESS_PHONE=+919500526217

# ==========================================
# HOW TO GET WHATSAPP API CREDENTIALS:
# ==========================================
# 1. Go to https://developers.facebook.com/
# 2. Create a new app or select existing one
# 3. Add "WhatsApp" product to your app
# 4. Get your Access Token from WhatsApp > API Setup
# 5. Get your Phone Number ID from WhatsApp > API Setup
# 6. Set a Verify Token (can be any string you choose)
# 7. Configure webhook URL: https://your-domain.com/webhook
# 8. Subscribe to messages event: messages
#
# For testing, use Meta's test number provided in the dashboard
# ==========================================

# ==========================================
# OPTIONAL: Email Notifications
# (If you want email alerts for new leads)
# ==========================================

# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# ADMIN_EMAIL=nlr66438@gmail.com

